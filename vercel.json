{
  "version": 2,
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/apps/admin/index.html" },
    { "source": "/livreur/(.*)", "destination": "/apps/livreur/index.html" },
    { "source": "/partner/(.*)", "destination": "/apps/partner/index.html" },
    { "source": "/(.*)", "destination": "/apps/client/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ]
}
